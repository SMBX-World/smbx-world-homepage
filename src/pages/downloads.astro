  <script>
    const buttons = document.querySelectorAll<HTMLAnchorElement>('.download-btn:not(.dl-link)');
    const panels = document.querySelectorAll<HTMLElement>('.version-panel');

    function switchVersion(version: string) {
      panels.forEach(panel => {
        panel.style.display = 'none';
      });
      const target = document.getElementById('panel-' + version);
      if (target) target.style.display = '';

      if (version === '38a') {
        const faq = document.getElementById('panel-38a-faq');
        if (faq) faq.style.display = '';
      }

      buttons.forEach(btn => btn.classList.remove('active'));
      const activeBtn = document.querySelector(`.download-btn[data-version="${version}"]`);
      if (activeBtn) activeBtn.classList.add('active');

      window.dispatchEvent(new Event('blockbox-resize'));
    }

    buttons.forEach(btn => {
      btn.addEventListener('click', e => {
        e.preventDefault();
        const version = btn.dataset.version;
        if (version) switchVersion(version);
      });
    });

    // Default: show legacy
    switchVersion('legacy');
  </script>
</BaseLayout>
