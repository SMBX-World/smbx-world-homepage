---
interface Props {
  color: 'blue' | 'green' | 'orange' | 'white';
}

const { color } = Astro.props;
---

<table id="everything" cellpadding="0" cellspacing="0" width="100%">
  <tr class={`${color}-top`}>
    <td class={`${color}-top-left`}></td>
    <td class={`${color}-top-center`}></td>
    <td class={`${color}-top-right`}></td>
  </tr>
  <tr class={`${color}-mid`}>
    <td class={`${color}-mid-left`}></td>
    <td class={`${color}-mid-center`}>
      <div class="blockbox-content">
        <slot />
      </div>
    </td>
    <td class={`${color}-mid-right`}></td>
  </tr>
  <tr class={`${color}-bot`}>
    <td class={`${color}-bot-left`}></td>
    <td class={`${color}-bot-center`}></td>
    <td class={`${color}-bot-right`}></td>
  </tr>
</table>

<script>
  function adjustBlockBoxHeight() {
    const midCenters = document.querySelectorAll('.blue-mid-center, .green-mid-center, .orange-mid-center, .white-mid-center');
    midCenters.forEach((el) => {
      const cell = el as HTMLElement;
      cell.style.paddingBottom = '0px';
      const height = cell.getBoundingClientRect().height;
      const remainder = height % 32;
      if (remainder !== 0) {
        cell.style.paddingBottom = `${32 - remainder}px`;
      }
    });
  }

  document.addEventListener('DOMContentLoaded', adjustBlockBoxHeight);
  window.addEventListener('resize', adjustBlockBoxHeight);
  window.addEventListener('blockbox-resize', adjustBlockBoxHeight);
</script>
