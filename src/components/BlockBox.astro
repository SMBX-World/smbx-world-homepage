---
interface Props {
  color: 'blue' | 'green' | 'orange' | 'white';
}

const { color } = Astro.props;
---

<table id="everything" cellpadding="0" cellspacing="0" width="100%">
  <tr class={`${color}-top`}>
    <td class={`${color}-top-left`}></td>
    <td class={`${color}-top-center`}></td>
    <td class={`${color}-top-right`}></td>
  </tr>
  <tr class={`${color}-mid`}>
    <td class={`${color}-mid-left`}></td>
    <td class={`${color}-mid-center`}>
      <slot />
    </td>
    <td class={`${color}-mid-right`}></td>
  </tr>
  <tr class={`${color}-bot`}>
    <td class={`${color}-bot-left`}></td>
    <td class={`${color}-bot-center`}></td>
    <td class={`${color}-bot-right`}></td>
  </tr>
</table>
